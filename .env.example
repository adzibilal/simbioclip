# SimbioClip configuration variables
API_TOKEN=admin

# 9 routers as a JSON array of objects. Fallbacks happen sequentially.
# Format: [{"base_url": "...", "api_key": "...", "model": "..."}]
LLM_ROUTERS=[{"base_url": "https://api.openai.com/v1", "api_key": "sk-your-key-here", "model": "simbioclip-model-router"}]

# STT Mode: 'router' for API offload, 'local' for local CPU faster-whisper execution
STT_MODE=local

# When STT_MODE=router, configure these to point to a Whisper-compatible endpoint (e.g. Groq, OpenAI)
STT_BASE_URL=https://api.openai.com/v1
STT_API_KEY=sk-your-key-here

# Whisper model (router mode). Primary is tried first; falls back to STT_MODEL_FALLBACK on error.
# Defaults target Groq. For OpenAI use STT_MODEL=whisper-1 and leave the fallback empty.
STT_MODEL=whisper-large-v3-turbo
STT_MODEL_FALLBACK=whisper-large-v3

# ---------------------------------------------------------------------------
# User settings (AI providers, watermark, credit, hook style) are managed via
# the Settings page and stored in data/config.json.
# See: /app/settings
# ---------------------------------------------------------------------------

# Public URL where SimbioClip is reachable (required for Repliz to fetch clips)
PUBLIC_BASE_URL=

# Repliz API credentials (optional — configure in Settings page)
REPLIZ_ACCESS_KEY=
REPLIZ_SECRET_KEY=
REPLIZ_DEFAULT_ACCOUNT_ID=
REPLIZ_AUTO_SCHEDULE=false
REPLIZ_SCHEDULE_OFFSET_MINUTES=5
REPLIZ_POST_TYPE=video

# S3/SeaweedFS storage (alternative to PUBLIC_BASE_URL for Repliz to fetch clips)
AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_DEFAULT_REGION=us-east-1
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_FOLDER_NAME=simbioclip

# ---------------------------------------------------------------------------
# Video Download (yt-dlp) — speed & cookies
# ---------------------------------------------------------------------------

# Path to Netscape-format cookies.txt (legacy method).
# Leave empty if you use COOKIES_FROM_BROWSER instead.
COOKIES_FILE=

# Browser to auto-extract cookies from. Takes priority over COOKIES_FILE.
# Supported: chrome, firefox, brave, chromium, edge, opera, safari
# Example: COOKIES_FROM_BROWSER=chrome
# If your browser needs a specific profile, use: COOKIES_FROM_BROWSER=firefox:+default
# Google Chrome is pre-installed in the docker image; run `python manage.py auth` for
# one-time YouTube login. After that, cookiesfrombrowser works automatically.
COOKIES_FROM_BROWSER=chrome

# Number of concurrent fragment downloads. Higher = faster for large DASH videos.
# Start with 5, max ~10 depending on your connection & server CPU.
CONCURRENT_FRAGMENTS=5

# aria2c external downloader — 16 parallel connections per file.
# Skyrockets download speed for all formats (not just DASH).
# Requires `aria2` installed in the container (included by default).
ARIA2C_ENABLED=true
ARIA2C_CONNECTIONS=16

# YouTube throttled-rate bypass. Set high to ignore speed limits.
# yt-dlp >=2024 feature.
THROTTLED_RATE=200M
