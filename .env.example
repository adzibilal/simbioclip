# SimbioClip configuration variables
API_TOKEN=super-secret-admin-token

# 9 routers as a JSON array of objects. Fallbacks happen sequentially.
# Format: [{"base_url": "...", "api_key": "...", "model": "..."}]
LLM_ROUTERS=[{"base_url": "https://api.openai.com/v1", "api_key": "sk-your-key-here", "model": "gpt-4o-mini"}]

# STT Mode: 'router' for API offload, 'local' for local CPU faster-whisper execution
STT_MODE=local

# When STT_MODE=router, configure these to point to a Whisper-compatible endpoint (e.g. Groq, OpenAI)
STT_BASE_URL=https://api.openai.com/v1
STT_API_KEY=sk-your-key-here

# Whisper model (router mode). Primary is tried first; falls back to STT_MODEL_FALLBACK on error.
# Defaults target Groq. For OpenAI use STT_MODEL=whisper-1 and leave the fallback empty.
STT_MODEL=whisper-large-v3-turbo
STT_MODEL_FALLBACK=whisper-large-v3
